# Copy this file to .env.local and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed locally to run `npm run upload-books` (do NOT deploy this key).
# Project Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your Claude API key, used by the dictionary "Fill with AI" helper.
# Get one at https://console.anthropic.com -> API Keys.
# Add the SAME key in Vercel: Project -> Settings -> Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...
